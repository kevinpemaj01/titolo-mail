<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>6ebbb67f-576e-4a49-af2c-ab6ee33fd7d9</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Studio Pemaj</ProviderName>
  <DefaultLocale>it-IT</DefaultLocale>
  <DisplayName DefaultValue="Titolo Mail"/>
  <Description DefaultValue="Genera un titolo riassuntivo della mail (data, mittente, destinatario, motivo) e scarica il file .eml gia' rinominato."/>
  <IconUrl DefaultValue="https://kevinpemaj01.github.io/titolo-mail/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://kevinpemaj01.github.io/titolo-mail/icon-128.png"/>
  <SupportUrl DefaultValue="https://www.studiopemaj.it"/>

  <AppDomains>
    <AppDomain>https://kevinpemaj01.github.io</AppDomain>
    <AppDomain>https://api.anthropic.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://kevinpemaj01.github.io/titolo-mail/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="grpTitoloMail">
                <Label resid="grp.Label"/>
                <Control xsi:type="Button" id="btnApriPannello">
                  <Label resid="btn.Label"/>
                  <Supertip>
                    <Title resid="btn.Label"/>
                    <Description resid="btn.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon.16"/>
                    <bt:Image size="32" resid="icon.32"/>
                    <bt:Image size="80" resid="icon.80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon.16" DefaultValue="https://kevinpemaj01.github.io/titolo-mail/icon-16.png"/>
        <bt:Image id="icon.32" DefaultValue="https://kevinpemaj01.github.io/titolo-mail/icon-32.png"/>
        <bt:Image id="icon.80" DefaultValue="https://kevinpemaj01.github.io/titolo-mail/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="taskpane.Url" DefaultValue="https://kevinpemaj01.github.io/titolo-mail/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="grp.Label" DefaultValue="Studio Pemaj"/>
        <bt:String id="btn.Label" DefaultValue="Titolo Mail"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="btn.Tooltip" DefaultValue="Genera il titolo riassuntivo (AAAA_MM_GG - Da X a Y - motivo) e scarica la mail rinominata."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
